    "tab.activeBorderTop": "#9C5B28",
    "tab.inactiveBackground": "#F0E6DA",
    "titleBar.activeBackground": "#E6D8C8",
    "titleBar.activeForeground": "#2E1E12",
    "titleBar.inactiveBackground": "#E6D8C8",
    "titleBar.inactiveForeground": "#8A7B6E",
    "editorInlayHint.foreground": "#8A7B6E",
    "editorInlayHint.background": "#F0EAE1",
    "editorHoverWidget.highlightForeground": "#9C3B1A",
    "terminal.background": "#FAF5F0",
    "terminal.foreground": "#2E1E12",
    "terminal.ansiBlack": "#2E1E12",
    "terminal.ansiRed": "#A82A1A",
    "terminal.ansiGreen": "#3A662C",
    "terminal.ansiYellow": "#A66314",
    "terminal.ansiBlue": "#4A6E8A",
    "terminal.ansiMagenta": "#8A4A7A",
    "terminal.ansiCyan": "#3A7A7A",
    "terminal.ansiWhite": "#EAE0D5",
    "terminal.ansiBrightBlack": "#8A7B6E",
    "terminal.ansiBrightRed": "#C94A30",
    "terminal.ansiBrightGreen": "#5C8A4A",
